---
import type { LandingContent, Locale } from '../content/locales';
import type { MediaImage } from '../content/media';
import ResponsivePicture from './ResponsivePicture.astro';

interface Props {
  content: LandingContent;
  locale: Locale;
  image: MediaImage;
}

const { content, locale, image } = Astro.props;
---
<section class="hero performance-hero" data-performance-hero>
  <div class="hero-copy">
    <p class="eyebrow">{content.hero.eyebrow}</p>
    <h1 data-motion="hero-title">{content.hero.title}</h1>
    <p class="lede">{content.hero.subtitle}</p>
    <div class="hero-actions">
      <a class="button button-primary" href="#apply">{content.hero.primaryCta}</a>
      <a class="button button-secondary" href="#support">{content.hero.secondaryCta}</a>
    </div>
  </div>
  <div class="hero-visual" data-motion="hero-image">
    <ResponsivePicture image={image} {locale} eager class="hero-picture" sizes="(min-width: 64rem) 50vw, 100vw" />
    <aside class="hero-fact hero-fact-income" data-motion-card>RM2,500–RM10,000+</aside>
    <aside class="hero-fact hero-fact-culture" data-motion-card>{content.culture.statement}</aside>
    <aside class="hero-fact hero-fact-growth" data-motion-card>{content.chrome.growthFact}</aside>
  </div>
</section>
