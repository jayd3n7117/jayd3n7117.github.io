---
import type { LandingContent, Locale } from '../content/locales';

interface Props {
  locale: Locale;
  content: LandingContent;
}

const { locale, content } = Astro.props;

const languageLinks = [
  { locale: 'en', label: 'English' },
  { locale: 'bm', label: 'Bahasa Malaysia' },
  { locale: 'zh', label: '中文' },
] as const;
---

<header class="site-header">
  <div class="shell section-inner header-inner">
    <a class="wordmark" href={`/${locale}/`} aria-label={content.chrome.homeLabel}>
      <span aria-hidden="true">COWAY</span>
    </a>

    <nav class="desktop-navigation" aria-label={content.chrome.primaryNavigationLabel}>
      <ul class="primary-navigation">
        <li><a href="#opportunity">{content.nav.opportunity}</a></li>
        <li><a href="#support">{content.nav.support}</a></li>
        <li><a href="#growth">{content.nav.culture}</a></li>
        <li><a href="#faq">{content.nav.faq}</a></li>
        <li><a href="#apply">{content.nav.apply}</a></li>
      </ul>
    </nav>

    <details class="mobile-navigation">
      <summary>{content.nav.menu}</summary>
      <nav aria-label={content.nav.menu}>
        <ul>
          <li><a href="#opportunity">{content.nav.opportunity}</a></li>
          <li><a href="#support">{content.nav.support}</a></li>
          <li><a href="#growth">{content.nav.culture}</a></li>
          <li><a href="#faq">{content.nav.faq}</a></li>
          <li><a href="#apply">{content.nav.apply}</a></li>
        </ul>
      </nav>
    </details>

    <div class="header-actions">
      <details class="language-menu">
        <summary aria-label={`${content.nav.language}: ${content.meta.language}`}>
          {content.meta.language}
        </summary>
        <ul>
          {
            languageLinks.map((language) => (
              <li>
                <a
                  href={`/${language.locale}/`}
                  data-locale-link
                  aria-current={language.locale === locale ? 'page' : undefined}
                >
                  {language.label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      <a class="button button-accent" href="#apply">{content.nav.apply}</a>
    </div>
  </div>
</header>
