---
import type { LandingContent, Locale } from '../content/locales';
import type { MediaImage } from '../content/media';
import ResponsivePicture from './ResponsivePicture.astro';

interface Props {
  content: LandingContent;
  locale: Locale;
  images: readonly MediaImage[];
}

const { content, locale, images } = Astro.props;
---
<section id="growth" class="section growth" data-reveal>
  <header class="section-heading">
    <h2>{content.progression.title}</h2>
    <p>{content.progression.body}</p>
  </header>
  <ol>
    {content.progression.steps.map((step, i) => <li><span>{i + 1}</span>{step}</li>)}
  </ol>
  <div class="proof-grid">
    {images.map((image) => (
      <ResponsivePicture {image} {locale} sizes="(min-width: 48rem) 33vw, 100vw" />
    ))}
  </div>
</section>
