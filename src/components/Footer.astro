---
import type { LandingContent, Locale } from '../content/locales';
import { getSocialLinkAttributes, socialProfiles, type SocialProfile } from '../config/social';

interface Props {
  locale: Locale;
  content: LandingContent;
  profiles?: readonly SocialProfile[];
}

const { locale, content, profiles = socialProfiles } = Astro.props;

const languageLinks = [
  { locale: 'en', label: 'English' },
  { locale: 'bm', label: 'Bahasa Malaysia' },
  { locale: 'zh', label: '中文' },
] as const;
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div>
      <p class="footer-wordmark" aria-label="Coway">COWAY</p>
      <p>{content.footer.copyright}</p>
    </div>

    <nav aria-label={content.nav.language}>
      <p class="footer-heading">{content.nav.language}</p>
      <ul class="footer-links language-links">
        {
          languageLinks.map((language) => (
            <li>
              <a
                href={`/${language.locale}/`}
                data-locale-link
                aria-current={language.locale === locale ? 'page' : undefined}
              >
                {language.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="footer-social">
      <p class="footer-heading">{content.footer.socialHeading}</p>
      <ul class="social-links">
        {profiles.map((profile) => {
          const attributes = getSocialLinkAttributes(profile.url);
          const unavailableLabel = `${profile.label}: ${content.footer.socialUnavailableLabel}`;

          return (
            <li>
              {attributes ? (
                <a class="social-link" data-social-platform={profile.id} {...attributes}>
                  {profile.label}
                </a>
              ) : (
                <span
                  class="social-link social-link-disabled"
                  data-social-platform={profile.id}
                  aria-disabled="true"
                  aria-label={unavailableLabel}
                >
                  {profile.label}
                </span>
              )}
            </li>
          );
        })}
      </ul>
    </div>
  </div>

  <div class="shell footer-legal">
    <p class="site-disclosure">{content.footer.disclaimer}</p>
    <a href="#privacy-note">{content.footer.privacyLink}</a>
    <p id="privacy-note" tabindex="-1">{content.footer.privacy}</p>
  </div>
</footer>
