---
import type { LandingContent } from '../content/locales'; const { content }=Astro.props as {content:LandingContent};
---
<section class="momentum"><div><p class="eyebrow">Momentum</p><h2>{content.momentum.title}</h2><p>{content.momentum.body}</p></div><ul>{content.support.items.slice(0,5).map(item=><li>{item.title}</li>)}</ul></section>
