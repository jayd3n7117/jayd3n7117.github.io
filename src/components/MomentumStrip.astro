---
import type { LandingContent } from '../content/locales';

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
---
<section class="momentum full-bleed" data-reveal>
  <div>
    <h2>{content.momentum.title}</h2>
    <p>{content.momentum.body}</p>
  </div>
  <div class="ticker-viewport">
    <ul data-ticker data-ticker-track>
      {content.support.items.slice(0, 5).map((item) => <li>{item.title}</li>)}
    </ul>
  </div>
</section>
